    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hpcc-js/wasm-graphviz": "^1.21.2",
    "@resvg/resvg-js": "^2.6.2",
    "picocolors": "^1.1.1"
  }
