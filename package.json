{
  "name": "depdo",
  "version": "0.1.0",
  "description": "Dependency-aware todo manager — tasks as a DAG, topological sort tells you what to do next",
  "module": "src/cli.ts",
  "type": "module",
  "files": ["src", "scripts"],
  "bin": {
    "depdo": "src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bash scripts/build.sh",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["todo", "task", "dag", "dependency", "graph", "cli", "topological-sort"],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hpcc-js/wasm-graphviz": "^1.21.2",
    "@resvg/resvg-js": "^2.6.2",
    "picocolors": "^1.1.1"
  }
}
