#!/bin/bash
# Block tag pushes if CHANGELOG.md has no entry for the version.

while read local_ref local_sha remote_ref remote_sha; do
  # Only check version tags
  if [[ "$local_ref" =~ ^refs/tags/v(.+)$ ]]; then
    VERSION="${BASH_REMATCH[1]}"
    if ! grep -qE "## \[?$VERSION\]?" CHANGELOG.md; then
      echo "ERROR: CHANGELOG.md has no entry for version $VERSION."
      echo "Add a '## [$VERSION]' section to CHANGELOG.md before pushing this tag."
      exit 1
    fi
  fi
done

exit 0
